# MinIO URL exposed to frontend/backends.
# For local development keep localhost, for servers replace with your IP/domain.
MINIO_CDN_HOST=http://localhost/bus-gallery

# SMTP settings for email OTP
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=example@qq.com
MAIL_PASSWORD=
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
AUTH_SECURITY_MAIL_ENABLED=true
AUTH_SECURITY_MAIL_FROM=example@qq.com
