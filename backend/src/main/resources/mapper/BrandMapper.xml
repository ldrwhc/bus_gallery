<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.busgallery.busgallery.mapper.BrandMapper">

    <resultMap id="BrandResultMap" type="com.busgallery.busgallery.entity.Brand">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="chnName" column="chn_name"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="BaseColumnList">
        id, name, chn_name, created_at, updated_at
    </sql>

    <select id="selectById" parameterType="long" resultMap="BrandResultMap">
        SELECT <include refid="BaseColumnList"/>
        FROM brand
        WHERE id = #{id}
    </select>

    <select id="selectByName" parameterType="string" resultMap="BrandResultMap">
        SELECT <include refid="BaseColumnList"/>
        FROM brand
        WHERE name = #{name}
        LIMIT 1
    </select>

    <select id="selectByChnName" parameterType="string" resultMap="BrandResultMap">
        SELECT <include refid="BaseColumnList"/>
        FROM brand
        WHERE chn_name = #{chnName}
        LIMIT 1
    </select>

    <select id="selectAll" resultMap="BrandResultMap">
        SELECT <include refid="BaseColumnList"/>
        FROM brand
        ORDER BY name
    </select>

    <insert id="insert" parameterType="com.busgallery.busgallery.entity.Brand"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO brand (name, chn_name)
        VALUES (#{name}, #{chnName})
    </insert>

    <update id="update" parameterType="com.busgallery.busgallery.entity.Brand">
        UPDATE brand
        SET
        name = #{name},
        chn_name = #{chnName}
        WHERE id = #{id}
    </update>

    <delete id="delete" parameterType="long">
        DELETE FROM brand WHERE id = #{id}
    </delete>
</mapper>