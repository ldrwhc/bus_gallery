<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.busgallery.busgallery.mapper.ModelMapper">

    <resultMap id="ModelResultMap" type="com.busgallery.busgallery.entity.Model">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <association property="brand" javaType="com.busgallery.busgallery.entity.Brand">
            <id property="id" column="brand_id"/>
        </association>
    </resultMap>

    <sql id="BaseColumnList">
        id, brand_id, name, description, created_at, updated_at
    </sql>

    <select id="selectById" parameterType="long" resultMap="ModelResultMap">
        SELECT <include refid="BaseColumnList"/>
        FROM model
        WHERE id = #{id}
    </select>

    <select id="selectByBrandAndName" resultMap="ModelResultMap">
        SELECT <include refid="BaseColumnList"/>
        FROM model
        WHERE brand_id = #{brandId}
        AND name = #{name}
        LIMIT 1
    </select>

    <select id="selectByBrandId" parameterType="long" resultMap="ModelResultMap">
        SELECT <include refid="BaseColumnList"/>
        FROM model
        WHERE brand_id = #{brandId}
        ORDER BY name
    </select>

    <select id="selectAll" resultMap="ModelResultMap">
        SELECT <include refid="BaseColumnList"/>
        FROM model
        ORDER BY brand_id, name
    </select>

    <insert id="insert" parameterType="com.busgallery.busgallery.entity.Model"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO model (name, description, brand_id)
        VALUES (#{name}, #{description}, #{brand.id})
    </insert>

    <update id="update" parameterType="com.busgallery.busgallery.entity.Model">
        UPDATE model
        SET
        name = #{name},
        description = #{description},
        brand_id = #{brand.id}
        WHERE id = #{id}
    </update>

    <delete id="delete" parameterType="long">
        DELETE FROM model WHERE id = #{id}
    </delete>
</mapper>
