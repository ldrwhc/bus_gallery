<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.busgallery.busgallery.mapper.RegionMapper">

    <resultMap id="RegionResultMap" type="com.busgallery.busgallery.entity.Region">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="parentId" column="parent_id"/>
        <result property="provinceId" column="province_id"/>
        <result property="level" column="level"/>
        <result property="regionType" column="region_type"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="BaseColumnList">
        id, name, parent_id, province_id, level, region_type, created_at, updated_at
    </sql>

    <select id="selectById" parameterType="long" resultMap="RegionResultMap">
        SELECT <include refid="BaseColumnList"/>
        FROM region
        WHERE id = #{id}
    </select>

    <select id="selectByName" parameterType="string" resultMap="RegionResultMap">
        SELECT <include refid="BaseColumnList"/>
        FROM region
        WHERE name = #{name}
        LIMIT 1
    </select>

    <select id="selectByNameAndParent" resultMap="RegionResultMap">
        SELECT <include refid="BaseColumnList"/>
        FROM region
        WHERE name = #{name}
        <if test="parentId == null">
            AND parent_id IS NULL
        </if>
        <if test="parentId != null">
            AND parent_id = #{parentId}
        </if>
        LIMIT 1
    </select>

    <select id="selectAll" resultMap="RegionResultMap">
        SELECT <include refid="BaseColumnList"/>
        FROM region
        ORDER BY level, name
    </select>

    <select id="selectByParentId" parameterType="long" resultMap="RegionResultMap">
        SELECT <include refid="BaseColumnList"/>
        FROM region
        WHERE parent_id = #{parentId}
        ORDER BY name
    </select>

    <select id="selectByProvinceId" parameterType="long" resultMap="RegionResultMap">
        SELECT <include refid="BaseColumnList"/>
        FROM region
        WHERE province_id = #{provinceId}
        ORDER BY
            CASE WHEN id = #{provinceId} THEN 0 ELSE 1 END,
            level,
            name
    </select>

    <select id="selectProvinceByName" parameterType="string" resultMap="RegionResultMap">
        SELECT <include refid="BaseColumnList"/>
        FROM region
        WHERE name = #{name}
          AND (
              region_type = 'PROVINCE'
              OR parent_id IS NULL
              OR level = 1
          )
        ORDER BY id ASC
        LIMIT 1
    </select>

    <select id="selectCityByNameAndProvince" resultMap="RegionResultMap">
        SELECT <include refid="BaseColumnList"/>
        FROM region
        WHERE name = #{name}
        <if test="provinceId != null">
            AND (province_id = #{provinceId} OR parent_id = #{provinceId})
        </if>
        <if test="provinceId == null">
            AND parent_id IS NOT NULL
        </if>
        ORDER BY id ASC
        LIMIT 1
    </select>

    <insert id="insert" parameterType="com.busgallery.busgallery.entity.Region"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO region (name, parent_id, province_id, level, region_type)
        VALUES (#{name}, #{parentId}, #{provinceId}, #{level}, #{regionType})
    </insert>

    <update id="update" parameterType="com.busgallery.busgallery.entity.Region">
        UPDATE region
        SET
        name = #{name},
        parent_id = #{parentId},
        province_id = #{provinceId},
        level = #{level},
        region_type = #{regionType}
        WHERE id = #{id}
    </update>

    <delete id="delete" parameterType="long">
        DELETE FROM region WHERE id = #{id}
    </delete>

</mapper>
